<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Thickness x:Key="CardPadding">20</Thickness>

    <Style x:Key="SurfaceCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    </Style>

    <Style x:Key="WarningCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
        <Setter Property="Background" Value="#26C68A00" />
        <Setter Property="BorderBrush" Value="#60C68A00" />
    </Style>

    <Style x:Key="HeroTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SectionLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Opacity" Value="0.72" />
    </Style>

    <Style x:Key="ValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="MutedBodyTextStyle" TargetType="TextBlock">
        <Setter Property="Opacity" Value="0.74" />
    </Style>

    <Style x:Key="AccentActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#0E5EEA" />
        <Setter Property="Foreground" Value="White" />
    </Style>
</ResourceDictionary>
